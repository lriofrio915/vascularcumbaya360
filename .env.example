# Resend (https://resend.com)
# API key obtenida desde el dashboard de Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email REMITENTE: debe pertenecer a un dominio verificado en Resend.
# Mientras no tengas dominio verificado, usa "onboarding@resend.dev"
# pero SOLO podrás recibir en el email con el que creaste la cuenta Resend.
RESEND_FROM_EMAIL=noreply@drpatriciogavilanes.com

# Email DESTINATARIO: donde recibirás los mensajes del formulario.
# Si usas "onboarding@resend.dev" como FROM, este debe ser el email
# con el que registraste tu cuenta en Resend.
RESEND_TO_EMAIL=info@drpatriciogavilanes.com
